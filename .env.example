# Telegram scrape alerts (api/seo.ts → scrape_guard)
# 1) Message @BotFather → /newbot → copy token
# 2) Message your bot once, then open:
#    https://api.telegram.org/bot<TOKEN>/getUpdates → copy chat.id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Optional: hits per IP per 5 min before alert (default 100)
# SCRAPE_ALERT_THRESHOLD=100
# Optional: minutes between alerts for the same IP (default 30m as ms)
# SCRAPE_ALERT_COOLDOWN_MS=1800000
