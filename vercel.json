{
  "framework": "react-router",
  "images": {
    "sizes": [16, 32, 48, 160, 256, 384, 640, 750, 828, 1080, 1280, 1920],
    "formats": ["image/webp"],
    "minimumCacheTTL": 86400
  },
  "rewrites": [
    { "source": "/storage/v1/render/image/public/:path*", "destination": "https://pkenrmorywmuvnzfoylp.supabase.co/storage/v1/render/image/public/:path*" },
    { "source": "/storage/v1/object/public/:path*", "destination": "https://pkenrmorywmuvnzfoylp.supabase.co/storage/v1/object/public/:path*" },

    { "source": "/api/film/:id", "destination": "/api/data?_r=films&id=:id" },
    { "source": "/api/channel/:id", "destination": "/api/data?_r=channels&id=:id" },
    { "source": "/api/admin/search-channels", "destination": "/api/data?_r=channels&action=yt_search" },
    { "source": "/api/films", "destination": "/api/data?_r=films" },
    { "source": "/api/people", "destination": "/api/data?_r=people" },
    { "source": "/api/channels", "destination": "/api/data?_r=channels" },
    { "source": "/api/content", "destination": "/api/data?_r=content" },

    { "source": "/api/youtube", "destination": "/api/external?provider=youtube" },
    { "source": "/api/tmdb", "destination": "/api/external?provider=tmdb" },

    { "source": "/api/health", "destination": "/api/media?op=health" },
    { "source": "/api/mirror-images", "destination": "/api/media?op=mirror" },

    { "source": "/api/scrape-imdb-actor", "destination": "/api/automation?action=scrape-imdb-actor" },
    { "source": "/api/deduplicator", "destination": "/api/automation?action=deduplicator" },
    { "source": "/api/people-enrichment", "destination": "/api/automation?action=people-enrichment" },

    { "source": "/api/cron/refresh-videos", "destination": "/api/cron/sync?task=refresh_videos" },
    { "source": "/api/cron/mirror-images", "destination": "/api/cron/sync?task=mirror_images" },

    { "source": "/sitemap.xml", "destination": "/api/seo?type=sitemap&slug=index" },
    { "source": "/sitemap-static.xml", "destination": "/api/seo?type=sitemap&slug=static" },
    { "source": "/sitemap-people.xml", "destination": "/api/seo?type=sitemap&slug=people" },
    { "source": "/sitemap-films.xml", "destination": "/api/seo?type=sitemap&slug=films" },
    { "source": "/sitemap-watch.xml", "destination": "/api/seo?type=sitemap&slug=watch" },
    { "source": "/sitemap-companies.xml", "destination": "/api/seo?type=sitemap&slug=companies" },
    { "source": "/sitemap-cinemas.xml", "destination": "/api/seo?type=sitemap&slug=cinemas" },
    { "source": "/sitemap-channels.xml", "destination": "/api/seo?type=sitemap&slug=channels" }
  ]
}
